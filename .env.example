# LLM 对话内容风控系统 — 环境变量配置
# 复制此文件为 .env 并填入你的 API Key
# .env 已在 .gitignore 中，不会被提交到 GitHub

# DeepSeek API Key（对话生成）
# 注册地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-key-here

# 规则管理令牌（启停/热更新接口；仅保存在本地 .env）
RULES_ADMIN_TOKEN=replace-with-a-local-admin-token

# SiliconFlow API Key（语义检测云端模式，可选）
# 注册地址: https://siliconflow.cn
SILICONFLOW_API_KEY=sk-your-key-here